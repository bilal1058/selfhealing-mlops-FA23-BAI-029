pipeline {
    agent any
    
    environment {
        KUBECTL = '/usr/local/bin/kubectl'
    }
    
    stages {
        stage('Switch Traffic to Stable (Green)') {
            steps {
                sh '${KUBECTL} patch service sentiment-api-service -p \'{"spec":{"selector":{"app":"sentiment-api","slot":"green"}}}\''
            }
        }
    }
}
